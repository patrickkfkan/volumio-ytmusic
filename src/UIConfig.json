{
  "page": {
    "label": "TRANSLATE.YTMUSIC_CONFIGURATION"
  },
  "sections": [
    {
      "id": "section_disclaimer",
      "element":" section",
      "label": "TRANSLATE.YTMUSIC_SECTION_DISCLAIMER",
      "icon": "fa-exclamation-triangle",
      "description": "TRANSLATE.YTMUSIC_DISCLAIMER_DESC",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/ytmusic",
        "method": "configSaveDisclaimer"
      },
      "saveButton": {
        "label": "TRANSLATE.YTMUSIC_SAVE",
        "data": [
          "hasAcceptedDisclaimer"
        ]
      },
      "content": [
        {
          "id": "viewDisclaimer",
          "element": "button",
          "label": "TRANSLATE.YTMUSIC_VIEW_DISCLAIMER",
          "onClick": {
            "type": "controller",
            "endpoint": "music_service/ytmusic",
            "method": "showDisclaimer"
          }
        },
        {
          "id": "hasAcceptedDisclaimer",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_ACCEPT",
          "value": false
        },
        {
          "id": "projectHome",
          "element": "button",
          "label": "TRANSLATE.YTMUSIC_PROJECT_HOME",
          "onClick": {
            "type": "openUrl",
            "url": "https://github.com/patrickkfkan/volumio-ytmusic"
          }
        }        
      ]
    },
    {
      "id": "section_i18n",
      "element": "section",
      "label": "TRANSLATE.YTMUSIC_SECTION_I18N",
      "icon": "fa-globe",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/ytmusic",
        "method": "configSaveI18n"
      },
      "saveButton": {
        "label": "TRANSLATE.YTMUSIC_SAVE",
        "data": [
          "region",
          "language"
        ]
      },
      "content": [
        {
          "id": "region",
          "element": "select",
          "label": "TRANSLATE.YTMUSIC_REGION",
          "value": {},
          "options": []
        },
        {
          "id": "language",
          "element": "select",
          "label": "TRANSLATE.YTMUSIC_LANGUAGE",
          "value": {},
          "options": []
        }
      ]
    },
    {
      "id": "section_account",
      "element": "section",
      "label": "TRANSLATE.YTMUSIC_SECTION_ACCOUNT",
      "icon": "fa-user",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/ytmusic",
        "method": "configSaveAccount"
      },
      "saveButton": {
        "label": "TRANSLATE.YTMUSIC_SAVE",
        "data": [
          "cookie"
        ]
      },
      "content": [
        {
          "id": "cookie",
          "element": "input",
          "type": "text",
          "label": "TRANSLATE.YTMUSIC_COOKIE",
          "doc": "TRANSLATE.YTMUSIC_DOC_COOKIE",
          "value": ""
        },
        {
          "id": "activeChannelHandle",
          "element": "select",
          "label": "TRANSLATE.YTMUSIC_ACTIVE_CHANNEL",
          "value": {},
          "options": []
        },
        {
          "id": "cookieGuide",
          "element": "button",
          "label": "TRANSLATE.YTMUSIC_COOKIE_GUIDE",
          "onClick": {
            "type": "openUrl",
            "url": "https://github.com/patrickkfkan/Volumio-YouTube.js/wiki/How-to-obtain-Cookie"
          }
        }
      ]
    },
    {
      "id": "section_browse",
      "element": "section",
      "label": "TRANSLATE.YTMUSIC_SECTION_BROWSE",
      "icon": "fa-cogs",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/ytmusic",
        "method": "configSaveBrowse"
      },
      "saveButton": {
        "label": "TRANSLATE.YTMUSIC_SAVE",
        "data": [
          "loadFullPlaylists"
        ]
      },
      "content": [
        {
          "id": "loadFullPlaylists",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_LOAD_FULL_PLAYLISTS",
          "doc": "TRANSLATE.YTMUSIC_DOC_LOAD_FULL_PLAYLISTS",
          "value": false
        }
      ]
    },
    {
      "id": "section_playback",
      "element": "section",
      "label": "TRANSLATE.YTMUSIC_SECTION_PLAYBACK",
      "icon": "fa-play",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/ytmusic",
        "method": "configSavePlayback"
      },
      "saveButton": {
        "label": "TRANSLATE.YTMUSIC_SAVE",
        "data": [
          "player",
          "autoplay",
          "autoplayClearQueue",
          "addToHistory",
          "prefetch",
          "preferOpus"
        ]
      },
      "content": [
        {
          "id": "player",
          "element": "select",
          "label": "TRANSLATE.YTMUSIC_PLAYER",
          "doc": "TRANSLATE.YTMUSIC_DOC_PLAYER",
          "options": [
            {
              "label": "TRANSLATE.YTMUSIC_PLAYER_MPD",
              "value": "mpd"
            },
            {
              "label": "TRANSLATE.YTMUSIC_PLAYER_VLC",
              "value": "vlc"
            },
            {
              "label": "TRANSLATE.YTMUSIC_PLAYER_MPV",
              "value": "mpv"
            }
          ],
          "value": {}
        },
        {
          "id": "autoplay",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_AUTOPLAY",
          "doc": "TRANSLATE.YTMUSIC_DOC_AUTOPLAY",
          "value": false
        },
        {
          "id": "autoplayClearQueue",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_AUTOPLAY_CLEAR_QUEUE",
          "doc": "TRANSLATE.YTMUSIC_DOC_AUTOPLAY_CLEAR_QUEUE",
          "value": false,
          "visibleIf": {
            "field": "autoplay",
            "value": true
          }
        },
        {
          "id": "addToHistory",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_ADD_TO_HISTORY",
          "doc": "TRANSLATE.YTMUSIC_DOC_ADD_TO_HISTORY",
          "value": true
        },
        {
          "id": "prefetch",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_PREFETCH_NEXT_TRACK",
          "value": true,
          "doc": "TRANSLATE.YTMUSIC_DOC_PREFETCH"
        },
        {
          "id": "preferOpus",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_PREFER_OPUS",
          "doc": "TRANSLATE.YTMUSIC_PREFER_OPUS_DESC",
          "value": false,
          "visibleIf": {
            "field": "prefetch",
            "value": true
          }
        }
      ]
    },
    {
      "id": "section_yt_dlp",
      "element": "section",
      "label": "TRANSLATE.YTMUSIC_SECTION_YT_DLP",
      "icon": "fa-download",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/ytmusic",
        "method": "configSaveYtDlp"
      },
      "saveButton": {
        "label": "TRANSLATE.YTMUSIC_SAVE",
        "data": [
          "useYtDlp",
          "ytDlpVersion"
        ]
      },
      "content": [
        {
          "id": "useYtDlp",
          "element": "switch",
          "label": "TRANSLATE.YTMUSIC_ENABLE_YT_DLP",
          "value": false,
          "doc": "TRANSLATE.YTMUSIC_DOC_USE_YT_DLP"
        },
        {
          "id": "ytDlpVersion",
          "element": "select",
          "label": "TRANSLATE.YTMUSIC_YT_DLP_VERSION",
          "options": [],
          "value": {}
        },
        {
          "id": "installLatestYtDlp",
          "element": "button",
          "label": "TRANSLATE.YTMUSIC_INSTALL_LATEST",
          "onClick": {
            "type": "controller",
            "endpoint": "music_service/ytmusic",
            "method": "installLatestYtDlp"
          }
        }
      ]
    }
  ]
}
